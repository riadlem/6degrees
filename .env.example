# Database (PostgreSQL — use Supabase, Railway, or local Docker)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sixdegrees"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# LinkedIn OAuth App
# Create at: https://www.linkedin.com/developers/apps
# Required products: Sign In with LinkedIn using OpenID Connect  ← needed for sign-in button
#                    Member Data Portability (EU/EEA only)       ← needed for contact sync
# Add redirect URI in LinkedIn app: {NEXTAUTH_URL}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Resend (password reset emails)
# Sign up at https://resend.com — free tier: 3,000 emails/month, 100/day
# Verify your sending domain in the Resend dashboard first.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Cowork (enrichment: photos, mutual connections)
# Included with Claude Max — configure API credentials here
COWORK_API_KEY=""
COWORK_API_URL=""
