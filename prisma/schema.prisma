datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

generator client {
  provider = "prisma-client-js"
}

// ─── NextAuth models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core models ─────────────────────────────────────────────────────────────

model User {
  id             String              @id @default(cuid())
  name           String?
  email          String?             @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  extensionToken String?             @unique
  syncCursor     Int?
  syncTotal      Int?
  accounts       Account[]
  sessions       Session[]
  contacts       Contact[]
  lists          ContactList[]
  labels         Label[]
  companyPrefs   CompanyPreference[]
  companyDomains CompanyDomain[]
  lastSyncAt     DateTime?
  gmailSyncs     GmailSync[]
  emailMessages  EmailMessage[]
  outreachDrafts OutreachDraft[]
  whatsAppMessages WhatsAppMessage[]
  whatsAppSync   WhatsAppSync?
  linkedInDMMessages     LinkedInDMMessage[]
  linkedInDMConversations LinkedInDMConversation[]
  linkedInDMSync LinkedInDMSync?
  userEmailAddresses UserEmailAddress[]
  dismissedEmails    DismissedEmail[]
  phoneContacts  PhoneContact[]
  eventSpeakers  EventSpeaker[]
  eventShares    EventShare[]
  contactShares  ContactShare[]
}

model Contact {
  id                String    @id @default(cuid())
  userId            String
  // Key from LinkedIn DMA
  linkedinKey       String
  // LinkedIn DMA CONNECTIONS fields
  firstName         String
  lastName          String
  position          String?
  company           String?
  connectedOn       DateTime?
  // Enriched via PROFILE domain or manual edit
  location          String?
  industry          String?
  headline          String?
  profileUrl        String?
  // Enriched via Cowork
  photoUrl          String?
  commonConnections Int?
  coworkEnrichedAt  DateTime?
  // Enriched via Chrome extension
  city              String?
  country           String?
  experience        Json?
  education         Json?
  sharedConnections Json?
  extensionSyncedAt DateTime?
  linkedinDegree    String?   // "1", "2", or "3" — scraped by extension at save time
  // Email interaction tracking
  emailAddress      String?
  phoneNumber       String?
  phones            String[]  // additional phone numbers (TEXT[] in Postgres)
  lockedFields      String[]  @default([]) // field names pinned by the user — enrichment sync won't overwrite (TEXT[] in Postgres)
  lastInteractionAt DateTime?
  interactionScore  Float?
  driftScore        Float?
  outreachStatus    String?
  outreachUpdatedAt DateTime?
  snoozedUntil      DateTime?
  // Metadata
  syncedAt          DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes            ContactNote[]
  listMembers      ContactListMember[]
  labels           ContactLabel[]
  emailMessages      EmailMessage[]
  emailAddresses     ContactEmailAddress[]
  outreachDrafts     OutreachDraft[]
  whatsAppMessages   WhatsAppMessage[]
  linkedInDMMessages     LinkedInDMMessage[]
  linkedInDMConversations LinkedInDMConversation[]
  eventSpeakerProfiles EventSpeaker[]

  @@unique([userId, linkedinKey])
  @@index([userId])
  @@index([userId, company])
  @@index([userId, industry])
  @@index([userId, interactionScore])
  @@index([userId, driftScore])
  @@index([userId, firstName])
  @@index([userId, lastName])
  @@index([userId, outreachStatus])
  @@index([userId, connectedOn])
  @@index([userId, extensionSyncedAt])
  @@index([userId, country])
}

model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ContactList {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  filterCompany  String?  // when set, list is dynamic: shows all contacts at this company
  filterSegment  String?  // JSON SegmentDef — smart list with arbitrary criteria
  shareToken    String?  @unique @default(cuid())
  shareEnabled  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  members ContactListMember[]

  @@index([userId])
}

model ContactListMember {
  id        String   @id @default(cuid())
  listId    String
  contactId String
  addedAt   DateTime @default(now())

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
}

model Label {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("blue")
  createdAt DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts ContactLabel[]

  @@unique([userId, name])
  @@index([userId])
}

model CompanyPreference {
  id            String  @id @default(cuid())
  userId        String
  company       String
  ignored       Boolean @default(false)
  isPartner     Boolean @default(false)
  size          String?
  type          String?
  parentCompany String?
  industry      String?
  website       String?
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, company])
  @@index([userId])
}

model CompanyDomain {
  id       String  @id @default(cuid())
  userId   String
  company  String
  domain   String
  excluded Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, company, domain])
  @@index([userId, company])
}

model ContactLabel {
  contactId  String
  labelId    String
  assignedAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  label   Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([contactId, labelId])
}

// ─── User email addresses ─────────────────────────────────────────────────────

model UserEmailAddress {
  id        String  @id @default(cuid())
  userId    String
  email     String
  isPrimary Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId])
}

model DismissedEmail {
  id        String   @id @default(cuid())
  userId    String
  email     String
  reason    String   @default("manual")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId])
}

// ─── Gmail integration ────────────────────────────────────────────────────────

model GmailSync {
  id            String    @id @default(cuid())
  userId        String
  gmailEmail    String
  historyId     String?
  syncedAt      DateTime?
  totalMessages Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailEmail])
}

model ContactEmailAddress {
  id        String  @id @default(cuid())
  contactId String
  email     String
  source    String
  isPrimary Boolean @default(false)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, email])
  @@index([email])
}

model EmailMessage {
  id         String   @id @default(cuid())
  userId     String
  gmailId    String
  threadId   String
  subject    String?  @db.Text
  fromEmail  String
  fromName   String?
  toEmails   String[]
  sentAt     DateTime
  isOutbound Boolean
  contactId  String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([userId, gmailId])
  @@index([userId, contactId])
  @@index([contactId, sentAt])
  @@index([userId, fromEmail])
}

model OutreachDraft {
  id        String    @id @default(cuid())
  contactId String
  userId    String
  subject   String?
  body      String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sentAt    DateTime?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contactId])
}

// ─── Phone / Address Book ─────────────────────────────────────────────────────

model PhoneContact {
  id          String  @id @default(cuid())
  userId      String
  fullName    String
  phone       String?
  email       String?
  birthday    String?   // ISO date "YYYY-MM-DD"
  photoData   String?   @db.Text
  linkedinUrl String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fullName])
  @@index([userId])
}

// ─── WhatsApp integration ─────────────────────────────────────────────────────

model WhatsAppSync {
  id            String    @id @default(cuid())
  userId        String    @unique
  importedAt    DateTime?
  totalMessages Int       @default(0)
  totalChats    Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WhatsAppMessage {
  id         String   @id @default(cuid())
  userId     String
  contactId  String?
  chatName   String
  sentAt     DateTime
  isOutbound Boolean
  phone      String?  // E.164 number from ZCONTACTJID, e.g. "+33612345678"
  senderName String?  // non-null for group messages; name/phone of sender
  isGroup    Boolean  @default(false)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([userId, chatName, sentAt])
  @@index([userId, contactId])
  @@index([contactId, sentAt])
}

// ─── LinkedIn Direct Messages integration ─────────────────────────────────────

model LinkedInDMConversation {
  id             String    @id @default(cuid())
  userId         String
  conversationId String
  chatName       String
  profileUrl     String?
  contactId      String?
  messageCount   Int       @default(0)
  importedAt     DateTime  @default(now())
  ignored        Boolean   @default(false)
  // Inbox-scan metadata (extension scrapes the conversation list on /messaging)
  lastInboxAt       DateTime?
  lastInboxOutbound Boolean?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([userId, conversationId])
  @@index([userId])
  @@index([userId, contactId])
}

model LinkedInDMSync {
  id            String    @id @default(cuid())
  userId        String    @unique
  importedAt    DateTime?
  totalMessages Int       @default(0)
  totalChats    Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LinkedInDMMessage {
  id             String   @id @default(cuid())
  userId         String
  contactId      String?
  conversationId String   // LinkedIn thread ID (stable across imports)
  chatName       String   // Other person's display name
  senderName     String   // FROM field value (may be user or contact)
  profileUrl     String?  // Other person's LinkedIn profile URL (used for matching)
  sentAt         DateTime
  isOutbound     Boolean

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([userId, conversationId, sentAt, senderName])
  @@index([userId, contactId])
  @@index([contactId, sentAt])
}

// ─── Event sharing ───────────────────────────────────────────────────────────

model EventShare {
  id           String   @id @default(cuid())
  userId       String
  eventSlug    String
  shareToken   String   @unique @default(cuid())
  shareEnabled Boolean  @default(false)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventSlug])
  @@index([userId])
}

// ─── Event speakers (e.g. Money 20/20) ───────────────────────────────────────

model EventSpeaker {
  id           String   @id @default(cuid())
  userId       String
  eventSlug    String   // e.g. "money2020-europe-2026"
  eventName    String   // e.g. "Money 20/20 Europe 2026"
  speakerKey   String   // stable key: eventSlug:firstName:lastName:company
  firstName    String
  lastName     String
  role         String?
  company      String?
  description  String?  @db.Text
  sessionTopic String?
  linkedinUrl  String?
  linkedinKey  String?  // LinkedIn profile slug
  photoUrl     String?
  contactId    String?  // set once speaker is added to contact base
  priority     Int?     // 1=must meet, 2=important, 3=optional, 4=skip (sorted last, grayed)
  importedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([userId, speakerKey])
  @@index([userId, eventSlug])
  @@index([userId, contactId])
}

// ─── Contact sharing ─────────────────────────────────────────────────────────

model ContactShare {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique @default(cuid())
  name        String?
  level       Int      @default(1)   // 1=basic, 2=+contact info, 3=+interaction
  filterType  String                 // "ids" | "company" | "segment"
  filterValue String   @db.Text     // JSON string[]: id list / company name / SegmentDef
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
