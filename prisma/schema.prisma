datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

generator client {
  provider = "prisma-client-js"
}

// ─── NextAuth models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core models ─────────────────────────────────────────────────────────────

model User {
  id             String        @id @default(cuid())
  name           String?
  email          String?       @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  extensionToken String?       @unique
  syncCursor     Int?
  syncTotal      Int?
  accounts       Account[]
  sessions       Session[]
  contacts       Contact[]
  lists          ContactList[]
  labels         Label[]
  companyPrefs   CompanyPreference[]
  lastSyncAt     DateTime?
}

model Contact {
  id               String    @id @default(cuid())
  userId           String
  // Key from LinkedIn DMA
  linkedinKey      String
  // LinkedIn DMA CONNECTIONS fields
  firstName        String
  lastName         String
  position         String?
  company          String?
  connectedOn      DateTime?
  // Enriched via PROFILE domain or manual edit
  location         String?
  industry         String?
  headline         String?
  profileUrl       String?
  // Enriched via Cowork
  photoUrl         String?
  commonConnections Int?
  coworkEnrichedAt DateTime?
  // Enriched via Chrome extension
  city              String?
  country           String?
  experience        Json?
  education         Json?
  sharedConnections Json?
  extensionSyncedAt DateTime?
  // Metadata
  syncedAt         DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes       ContactNote[]
  listMembers ContactListMember[]
  labels      ContactLabel[]

  @@unique([userId, linkedinKey])
  @@index([userId])
  @@index([userId, company])
  @@index([userId, industry])
}

model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ContactList {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  shareToken  String?  @unique @default(cuid())
  shareEnabled Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  members ContactListMember[]

  @@index([userId])
}

model ContactListMember {
  id        String      @id @default(cuid())
  listId    String
  contactId String
  addedAt   DateTime    @default(now())

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
}

model Label {
  id        String         @id @default(cuid())
  userId    String
  name      String
  color     String         @default("blue")
  createdAt DateTime       @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts ContactLabel[]

  @@unique([userId, name])
  @@index([userId])
}

model CompanyPreference {
  id        String   @id @default(cuid())
  userId    String
  company   String
  ignored   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, company])
  @@index([userId])
}

model ContactLabel {
  contactId  String
  labelId    String
  assignedAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  label   Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([contactId, labelId])
}
